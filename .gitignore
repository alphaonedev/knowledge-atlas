# --- Secrets ---
.env
*.env.local
secrets.json

# --- Per-source data (raw transcripts, derived knowledge) ---
# Anything indexed from third-party sources stays out of the repo.
transcripts/
raw_srt/
sources/
channel_metadata.json
sources.json
data/knowledge/*.json
data/knowledge.db
data/lexicon.db
data/export/

# --- Service-lifecycle state (atlas start/stop/status) ---
data/atlas.pid
data/atlas.log
data/atlas.log.*

# --- Per-maintainer private red-team patterns ---
# Each maintainer maintains their own list of private handles / emails / paths
# that must never appear in a public commit. Keeping this file local prevents
# the patterns themselves from leaking what each instance has indexed.
.red_team_local.txt

# --- Static assets generated at build time ---
static/charts/

# --- Python build artifacts ---
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/

# --- macOS / editor noise ---
.DS_Store
*.swp
.vscode/
.idea/

# --- Logs / backups ---
*.log
*.bak
*.bak-*
